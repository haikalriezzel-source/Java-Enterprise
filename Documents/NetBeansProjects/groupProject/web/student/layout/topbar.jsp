<%@page contentType="text/html" pageEncoding="UTF-8"%>
<% String pageTitle=(request.getAttribute("pageTitle")!=null)?(String)request.getAttribute("pageTitle"):"Student Portal"; String pageSubtitle=(request.getAttribute("pageSubtitle")!=null)?(String)request.getAttribute("pageSubtitle"):"Manage your facility bookings and equipment loans."; Object nm=session.getAttribute("studentName"); if(nm==null) nm=session.getAttribute("userID"); if(nm==null) nm=session.getAttribute("studentID"); %>
<header class="student-topbar d-flex align-items-center justify-content-between gap-3">
    <div class="d-flex align-items-center gap-3"><button class="btn btn-student-soft d-lg-none" type="button" id="studentSidebarToggle"><i class="fa-solid fa-bars"></i></button><div><h1 class="student-page-title fs-4"><%=pageTitle%></h1><div class="student-page-subtitle"><%=pageSubtitle%></div></div></div>
    <div class="d-flex align-items-center gap-2"><div class="dropdown"><a class="d-flex align-items-center gap-2 text-decoration-none" href="#" data-bs-toggle="dropdown"><span class="student-avatar"><%= nm!=null?nm.toString().substring(0,1).toUpperCase():"S" %></span><span class="d-none d-sm-inline fw-bold text-dark"><%= nm!=null?nm:"Student" %></span><i class="fa-solid fa-chevron-down student-muted small"></i></a><ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4"><li><a class="dropdown-item" href="<%=request.getContextPath()%>/studentDashboard"><i class="fa-solid fa-chart-pie me-2"></i>View Profile</a></li><li><a class="dropdown-item" href="<%=request.getContextPath()%>/EditStudentProfileServlet"><i class="fa-regular fa-user me-2"></i>Edit Profile</a></li><li><hr class="dropdown-divider"></li><li><a class="dropdown-item text-danger" href="<%=request.getContextPath()%>/LogoutServlet" onclick="return confirm('Are you sure you want to logout?');"><i class="fa-solid fa-right-from-bracket me-2"></i>Logout</a></li></ul></div></div>
</header>
<script>document.addEventListener('DOMContentLoaded',function(){var b=document.getElementById('studentSidebarToggle');var s=document.getElementById('studentSidebar');var o=document.getElementById('studentOverlay');if(b&&s){b.addEventListener('click',function(){s.classList.toggle('show');if(o)o.classList.toggle('show');});if(o)o.addEventListener('click',function(){s.classList.remove('show');o.classList.remove('show');});}});</script>

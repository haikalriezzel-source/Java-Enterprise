<%@page contentType="text/html" pageEncoding="UTF-8"%><%@page import="java.time.LocalDate"%><% request.setAttribute("pageTitle","Book Facility"); request.setAttribute("pageSubtitle","Choose your booking date, time and purpose."); String facilityID=request.getParameter("facilityID"); %>
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Book Facility</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet"><link href="<%=request.getContextPath()%>/assets/css/student.css" rel="stylesheet"></head><body class="student-ui-body"><div class="student-shell"><jsp:include page="layout/sidebar.jsp"/><div class="student-main"><jsp:include page="layout/topbar.jsp"/><main class="student-content"><div class="row justify-content-center"><div class="col-lg-7"><div class="student-card card"><div class="card-header"><i class="fa-solid fa-calendar-check me-2 text-primary"></i>Booking Details</div><div class="card-body p-4"><form action="<%=request.getContextPath()%>/BookFacilityServlet" method="post"><input type="hidden" name="facilityID" value="<%=facilityID%>"><div class="row g-3"><div class="col-md-6"><label class="form-label">Booking Date</label><input class="form-control" type="date" name="bookingDate" min="<%= LocalDate.now() %>" required></div><div class="col-md-6"><label class="form-label">Participants</label><input class="form-control" type="number" name="participants" min="1" required></div><div class="col-md-6"><label class="form-label">Start Time</label><input class="form-control" type="time" name="startTime" required></div><div class="col-md-6"><label class="form-label">End Time</label><input class="form-control" type="time" name="endTime" required></div><div class="col-12"><label class="form-label">Purpose</label><input class="form-control" type="text" name="purpose" required></div></div><div class="d-flex justify-content-end gap-2 mt-4"><a class="btn btn-student-soft" href="<%= request.getContextPath() %>/facilityList">Back To Facility List</a><input class="btn btn-student-primary" type="submit" value="Submit Booking"></div></form></div></div></div></div></main></div></div><script>document.querySelector('input[name="startTime"]').addEventListener('change',function(){document.querySelector('input[name="endTime"]').min=this.value;});</script><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script></body></html>
